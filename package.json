  "scripts": {
    "prestart": "node scripts/sync-cloudinary-images.js",
    "start": "concurrently \"npm run start-frontend\" \"npm run start-backend\" \"npm run start-server\"",
    "start-frontend": "react-scripts start",
    "start-backend": "node server/update-dest-image.js",
    "start-server": "cd server && node index.js",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "update-top-rated": "node scripts/updateTopRatedDestinations.js"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "babel-jest": "^30.1.2",
    "concurrently": "^9.2.1",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-jest": "^29.0.1",
    "jest": "^27.5.1",
    "jest-environment-jsdom": "^27.5.1"
  },
  "jest": {
    "transformIgnorePatterns": [
      "node_modules/(?!(react-router-dom|react-router)/)"
    ],
    "moduleNameMapper": {
      "^.+\\.(css|less|scss|sass)$": "<rootDir>/src/__mocks__/styleMock.js",
      "^axios$": "axios/dist/node/axios.cjs",
      "^@testing-library/react/dist/act-compat$": "<rootDir>/src/__mocks__/rtl-act-compat.js"
    }
  },
  "engines": {
    "node": ">=18 <21",
    "npm": ">=8"
  },
  "proxy": "http://localhost:3002"
