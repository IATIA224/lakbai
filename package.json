{
  "name": "lakbai-ai",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.11.0",
    "cloudinary": "^2.7.0",
    "cloudinary-react": "^1.8.1",
    "cors": "^2.8.5",
    "docx": "^9.5.1",
    "firebase": "^11.10.0",
    "firebase-admin": "^13.4.0",
    "glob": "^11.0.3",
    "jspdf": "^3.0.2",
    "jspdf-autotable": "^5.0.2",
    "leaflet": "^1.9.4",
    "leaflet-defaulticon-compatibility": "^0.1.2",
    "leaflet-routing-machine": "^3.2.12",
    "mapbox-gl": "^3.14.0",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.0.0",
    "react-icons": "^5.5.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.14.0",
    "react-scripts": "^5.0.1",
    "react-toastify": "^11.0.5",
    "toastify": "^2.0.1",
    "web-vitals": "^2.1.4",
    "cpx": "^1.5.0"
  },
  "scripts": {
    "prestart": "node scripts/sync-cloudinary-images.js",
    "start": "concurrently \"npm run start-frontend\" \"npm run start-backend\" \"npm run start-server\"",
    "start-frontend": "react-scripts start",
    "start-backend": "node server/update-dest-image.js",
    "start-server": "cd server && node index.js",
    "build": "react-scripts build",
    "postbuild": "cpx \"public/_redirects\" build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "babel-jest": "^30.1.2",
    "concurrently": "^9.2.1",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-jest": "^29.0.1",
    "jest": "^27.5.1",
    "jest-environment-jsdom": "^30.1.2"
  },
  "jest": {
    "transformIgnorePatterns": [
      "node_modules/(?!(react-router-dom|react-router)/)"
    ],
    "moduleNameMapper": {
      "^.+\\.(css|less|scss|sass)$": "<rootDir>/src/__mocks__/styleMock.js",
      "^axios$": "axios/dist/node/axios.cjs",
      "^@testing-library/react/dist/act-compat$": "<rootDir>/src/__mocks__/rtl-act-compat.js"
    }
  },
  "engines": {
    "node": ">=18 <21",
    "npm": ">=8"
  },
  "proxy": "http://localhost:3002"
}
